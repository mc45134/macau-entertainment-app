[project]
entrypoint = "server.js"
requires = [ "nodejs-24" ]
template = "expo"
version = "0.0.24"
appliedPatches = [ ]
project_type = "app"

[preview]
preview_enable = "disabled"

[dev]
build = [ "bash", ".cozeproj/scripts/dev_build.sh" ]
run = [ "bash", ".cozeproj/scripts/dev_run.sh" ]
validate = [ "bash", ".cozeproj/scripts/validate.sh" ]

[deploy]
build_app_dir = "./client"
